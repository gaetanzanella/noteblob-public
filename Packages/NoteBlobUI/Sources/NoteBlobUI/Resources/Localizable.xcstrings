    "auth.token_hint" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Create a personal access token with **repo** scope — [generate one on GitHub](https://github.com/settings/tokens/new?scopes=repo&description=NoteBlob). The token is stored in the keychain and embedded in each repository URL."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Créez un jeton d'accès personnel avec la portée **repo** — [générez-en un sur GitHub](https://github.com/settings/tokens/new?scopes=repo&description=NoteBlob). Le jeton est stocké dans le trousseau et intégré à l'URL de chaque dépôt."
          }
        }
      }
    },
