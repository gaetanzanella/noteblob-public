    "branch_picker.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NoteBlob uses a simple pull request workflow: each change is committed to its own branch, pushed, and merged via a pull request. Pick the branch that pull requests should target."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NoteBlob utilise un workflow simple basé sur les pull requests : chaque modification est committée sur une branche dédiée, puis poussée et fusionnée via une pull request. Choisissez la branche cible des pull requests."
          }
        }
      }
    },
