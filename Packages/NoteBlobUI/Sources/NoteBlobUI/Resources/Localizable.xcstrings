    "account.authenticated.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clearing the token will sign you out of GitHub. The token is also stored in each repository URL — delete the folder to fully remove it."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprimer le jeton vous déconnectera de GitHub. Le jeton est aussi stocké dans chaque URL de dépôt — supprimez le dossier pour le retirer complètement."
          }
        }
      }
